{
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm ci",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/v1/preview/route.ts": {
      "memory": 1024,
      "maxDuration": 30
    },
    "src/app/api/v1/preview/batch/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/v1/screenshot/route.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
